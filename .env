# .env

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Application ───────────────────────────────────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=docker

# ── Worker Pool ───────────────────────────────────────────────────
# How many threads process jobs concurrently
WORKER_POOL_SIZE=4

# Max jobs waiting in queue before backpressure kicks in
JOB_QUEUE_CAPACITY=1000

# ── Rate Limiter Defaults ─────────────────────────────────────────
# Applied to any tenant not explicitly registered
RATE_LIMITER_DEFAULT_CAPACITY=100
RATE_LIMITER_DEFAULT_RATE_PER_SECOND=50

# ── DLQ ───────────────────────────────────────────────────────────
DLQ_MAX_SIZE=500

# ── Retry ─────────────────────────────────────────────────────────
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=30000